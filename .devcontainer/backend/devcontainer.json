{
  "name": "Backend Dev Container",
  "dockerComposeFile": [
    "../../docker-compose.yml",
    "../../docker-compose.override.yml"
  ],
  "service": "backend",
  "workspaceFolder": "/home/app",
  "forwardPorts": [
    8080,
    5005
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot"
      ]
    }
  },
  "postStartCommand": "mvn --version"
}